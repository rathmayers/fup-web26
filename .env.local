# Sanity CMS
# Get these from https://sanity.io/manage → your project
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-01-01

# Sanity API Token (for server-side preview / mutations)
# Create a token with "Editor" permissions in Sanity Manage
SANITY_API_TOKEN=your_token_here

# Site URL (used for sitemap, OG tags etc.)
NEXT_PUBLIC_SITE_URL=https://www.fup-ag.com
